# 텔레그램 봇 토큰 (@BotFather 에서 /newbot 으로 발급)
BUDGET_BOT_TOKEN=1234567890:ABCdefGHIjklMNOpqrSTUvwxYZ

# 관리자(본인) 텔레그램 유저 ID
# 확인: @userinfobot 에서 /start 를 누르면 표시됨
ADMIN_USER_ID=123456789

# Google Sheets 스프레드시트 ID
# URL: https://docs.google.com/spreadsheets/d/{SPREADSHEET_ID}/edit
SPREADSHEET_ID=your_spreadsheet_id_here

# Google Service Account JSON 파일 경로 (기본값: credentials.json)
GOOGLE_CREDS_PATH=credentials.json

# 대시보드 URL (봇 기록 후 캐시 자동 초기화용, 미설정 시 비활성)
# 예: http://localhost:8080 또는 http://your-server-ip:8080
DASHBOARD_URL=
DASHBOARD_USER=admin
DASHBOARD_PASS=your_dashboard_password
